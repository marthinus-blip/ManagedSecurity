{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ProxyServerSettings": {
    "EnableTls": true,
    "TlsPort": 8443,
    "HttpPort": 8080,
    "EnforceLightweightCiphers": true
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "stream-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/stream/{**catch-all}"
        }
      },
      "ui-route": {
        "ClusterId": "ui-cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api/destination1": {
            "Address": "http://127.0.0.1:5188/"
          }
        }
      },
      "ui-cluster": {
        "Destinations": {
          "ui/destination1": {
            "Address": "http://127.0.0.1:5000/"
          }
        }
      }
    }
  }
}
